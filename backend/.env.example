# ─────────────────────────────────────────────
# Environment Configuration
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS – set to your frontend URL in production
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# App
APP_NAME=AI Student Performance Dashboard
APP_VERSION=1.0.0
DEBUG=True

# Database
# Dev (SQLite): leave unset to use database/sqlite/database.db
# Prod (Postgres): postgresql+psycopg://postgres:postgres@localhost:5432/student_dashboard
DATABASE_URL=
